{
  "name": "@map-gesture-controls/core",
  "version": "0.1.5",
  "description": "Map-agnostic hand gesture detection and state machine (MediaPipe)",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./style.css": "./dist/style.css"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build:lib": "tsc -p tsconfig.lib.json && vite build --config vite.lib.config.ts",
    "type-check": "tsc --noEmit"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.14"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  },
  "keywords": [
    "mediapipe",
    "hand-gestures",
    "gesture-detection",
    "gesture-recognition",
    "hand-tracking",
    "webcam",
    "touchless",
    "hands-free",
    "accessibility",
    "computer-vision",
    "wasm",
    "kiosk",
    "map",
    "interaction"
  ],
  "homepage": "https://sanderdesnaijer.github.io/map-gesture-controls/",
  "repository": {
    "type": "git",
    "url": "https://github.com/sanderdesnaijer/map-gesture-controls.git",
    "directory": "packages/map-gesture-core"
  },
  "bugs": {
    "url": "https://github.com/sanderdesnaijer/map-gesture-controls/issues"
  },
  "author": "Sander de Snaijer",
  "overrides": {
    "esbuild": "^0.25.0"
  },
  "license": "MIT"
}
